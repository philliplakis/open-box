{
  "name": "open-box",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "deploy:web": "bun run --cwd apps/web deploy",
    "deploy:web:preview": "bun run --cwd apps/web deploy:preview",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "workspaces": ["apps/*", "packages/*"],
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "bun@1.3.14"
}
