{
  "name": "@open-box/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check-types": "tsc -b",
    "lint": "oxlint",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler pages deploy dist --project-name open-box --branch main",
    "deploy:preview": "bun run build && wrangler pages deploy dist --project-name open-box --branch preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wrangler": "^4.107.0"
  }
}
